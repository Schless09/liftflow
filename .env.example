# Clerk (https://clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Multi-tenant Supabase: enable Clerk’s native Supabase integration in Clerk (copy Clerk domain),
# then Supabase Dashboard → Authentication → Sign In / Up → add provider → Clerk and paste that domain.
# Session tokens (not a deprecated JWT template) carry claims for RLS auth.jwt()->>'sub'.

# Supabase (https://supabase.com) — URL + anon/publishable key (any one row per variable is enough)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Or Supabase "publishable" key (sb_publishable_...):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_URL=  same as NEXT_PUBLIC_SUPABASE_URL
# SUPABASE_ANON_KEY=  or NEXT_PUBLIC_SUPABASE_KEY=  (Clerk/Supabase docs naming)
# Server-only; optional but recommended for writes in production
SUPABASE_SERVICE_ROLE_KEY=
# After migrate: private bucket `progress-photos` + table `progress_photos` for profile uploads (RLS uses Clerk JWT sub).

# Google Gemini (https://ai.google.dev/)
GEMINI_API_KEY=
# Optional override (default gemini-2.5-flash — stable ID for new AI Studio keys)
# GEMINI_MODEL=gemini-2.5-flash
